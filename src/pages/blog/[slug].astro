---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.status === 'published');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const catLabel: Record<string, string> = {
  seo: 'SEO', adsense: '애드센스', content: '콘텐츠 마케팅',
  trend: '마케팅 트렌드', tip: '마케팅 팁', case: '업종별 사례'
};
const tagStyle: Record<string, string> = {
  seo: 'background:var(--primary-light);color:var(--primary)',
  adsense: 'background:var(--accent-light);color:var(--accent)',
  content: 'background:var(--green-light);color:var(--green)',
  trend: 'background:#fff8ec;color:#f5a623',
  tip: 'background:#f0e8ff;color:#7c3aed',
  case: 'background:#fff8e1;color:#b45309',
};
---
<BaseLayout
  title={`${post.data.title} — JNC마케팅`}
  description={post.data.summary}
>
<style>
  .progress-bar { position: fixed; top: 68px; left: 0; z-index: 99; height: 3px; background: var(--primary); width: 0%; transition: width 0.1s; }

  .page-wrap { max-width: 1280px; margin: 0 auto; padding: 0 5%; display: grid; grid-template-columns: 1fr 300px; gap: 60px; padding-top: 48px; padding-bottom: 100px; }

  .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--gray-400); margin-bottom: 24px; }
  .breadcrumb a { transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--black); }
  .breadcrumb-sep { font-size: 11px; }

  .article-title { font-family: var(--font-serif); font-size: clamp(28px, 4vw, 44px); line-height: 1.25; letter-spacing: -0.02em; margin-bottom: 16px; }
  .article-excerpt { font-size: 17px; color: var(--gray-600); line-height: 1.75; margin-bottom: 24px; max-width: 640px; }
  .article-meta-bar { display: flex; align-items: center; gap: 14px; margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid var(--gray-200); }
  .author-avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--primary-light); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
  .author-name { font-size: 15px; font-weight: 700; }
  .article-date { font-size: 13px; color: var(--gray-400); }
  .article-stats { margin-left: auto; font-size: 13px; color: var(--gray-400); }

  .article-hero-img { width: 100%; aspect-ratio: 16/9; background: linear-gradient(135deg,#e8f0ff,#c5d5ff); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; font-size: 80px; margin-bottom: 40px; }

  /* ARTICLE BODY */
  .article-body { font-size: 16px; line-height: 1.9; color: var(--black); }
  .article-body h2 { font-family: var(--font-serif); font-size: clamp(22px, 2.5vw, 28px); font-weight: 700; line-height: 1.35; letter-spacing: -0.01em; margin: 48px 0 20px; padding-bottom: 12px; border-bottom: 2px solid var(--gray-100); }
  .article-body h3 { font-size: 20px; font-weight: 700; margin: 32px 0 14px; color: var(--black); }
  .article-body p { margin-bottom: 20px; }
  .article-body ul, .article-body ol { padding-left: 24px; margin-bottom: 20px; }
  .article-body li { margin-bottom: 8px; line-height: 1.75; }
  .article-body strong { font-weight: 700; color: var(--black); }
  .article-body a { color: var(--primary); text-decoration: underline; }
  .article-body blockquote { border-left: 3px solid var(--primary); padding: 16px 20px; margin: 24px 0; background: var(--primary-light); border-radius: 0 8px 8px 0; font-style: italic; color: var(--gray-600); }
  .article-body hr { border: none; border-top: 1px solid var(--gray-200); margin: 40px 0; }
  .article-body code { background: var(--gray-100); padding: 2px 6px; border-radius: 4px; font-size: 14px; }
  .article-body pre { background: var(--black); color: white; padding: 20px 24px; border-radius: 10px; overflow-x: auto; margin-bottom: 20px; }
  .article-body pre code { background: none; padding: 0; color: inherit; }
  .article-body img { width: 100%; border-radius: var(--radius); margin: 24px 0; }

  /* SIDEBAR */
  .article-sidebar { position: sticky; top: 88px; height: fit-content; }
  .toc-card { background: white; border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow-sm); margin-bottom: 20px; }
  .toc-title { font-size: 13px; font-weight: 700; color: var(--gray-400); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px; }
  .toc-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .toc-item a { font-size: 13px; color: var(--gray-600); transition: color 0.2s; line-height: 1.5; display: block; }
  .toc-item a:hover { color: var(--primary); }
  .toc-item.h3 { padding-left: 12px; }

  .cta-card { background: var(--primary); border-radius: var(--radius); padding: 24px; }
  .cta-card-title { font-family: var(--font-serif); font-size: 18px; color: white; margin-bottom: 10px; line-height: 1.4; }
  .cta-card-desc { font-size: 13px; color: rgba(255,255,255,0.65); margin-bottom: 18px; line-height: 1.65; }
  .cta-card-btn { display: block; background: white; color: var(--primary); text-align: center; padding: 11px; border-radius: 8px; font-size: 14px; font-weight: 700; transition: transform 0.15s; }
  .cta-card-btn:hover { transform: translateY(-2px); }

  /* TAGS */
  .article-tags-bottom { margin-top: 48px; padding-top: 32px; border-top: 1px solid var(--gray-200); display: flex; flex-wrap: wrap; gap: 8px; }
  .tag-chip { font-size: 13px; padding: 6px 14px; border-radius: 100px; background: var(--gray-100); color: var(--gray-600); transition: background 0.2s; }
  .tag-chip:hover { background: var(--gray-200); }

  @media (max-width: 1024px) {
    .page-wrap { grid-template-columns: 1fr; }
    .article-sidebar { display: none; }
  }
  @media (max-width: 768px) {
    .page-wrap { padding: 24px 20px 80px; }
    .article-hero-img { font-size: 56px; }
  }
</style>

<div class="progress-bar" id="progressBar"></div>

<div class="page-wrap">
  <main>
    <div class="breadcrumb">
      <a href="/">홈</a>
      <span class="breadcrumb-sep">›</span>
      <a href="/blog/">블로그</a>
      <span class="breadcrumb-sep">›</span>
      <span>{catLabel[post.data.category] || post.data.category}</span>
    </div>

    <div style="margin-bottom:14px;">
      <span class="blog-tag" style={tagStyle[post.data.category]}>{catLabel[post.data.category] || post.data.category}</span>
      {post.data.tags?.map(tag => (
        <span class="blog-tag" style="background:var(--gray-100);color:var(--gray-600);margin-left:6px;">{tag}</span>
      ))}
    </div>

    <h1 class="article-title">{post.data.title}</h1>
    {post.data.summary && <p class="article-excerpt">{post.data.summary}</p>}

    <div class="article-meta-bar">
      <div class="author-avatar">👨‍💼</div>
      <div>
        <div class="author-name">JNC마케팅팀</div>
        <div class="article-date">{post.data.date} {post.data.readTime && `· ${post.data.readTime}`}</div>
      </div>
    </div>

    <div class="article-hero-img">📈</div>

    <div class="article-body">
      <Content />
    </div>

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="article-tags-bottom">
        {post.data.tags.map(tag => <span class="tag-chip">#{tag}</span>)}
      </div>
    )}
  </main>

  <aside class="article-sidebar">
    <div class="toc-card">
      <div class="toc-title">목차</div>
      <ul class="toc-list" id="tocList">
        <li class="toc-item"><a href="#">로딩 중...</a></li>
      </ul>
    </div>
    <div class="cta-card">
      <div class="cta-card-title">마케팅, 어디서부터 시작할지 모르겠다면?</div>
      <div class="cta-card-desc">30분 무료 상담으로 현황 진단과 우선순위를 짚어드립니다.</div>
      <a class="cta-card-btn" href="/#contact">무료 상담 신청 →</a>
    </div>
  </aside>
</div>

<script>
  // 프로그레스 바
  const bar = document.getElementById('progressBar');
  const body = document.querySelector('.article-body') as HTMLElement;
  window.addEventListener('scroll', () => {
    if (!bar || !body) return;
    const total = body.offsetHeight - window.innerHeight;
    const scrolled = Math.max(0, window.scrollY - (body.offsetTop || 0));
    bar.style.width = Math.min(100, (scrolled / total) * 100) + '%';
  });

  // TOC 자동 생성
  const headings = document.querySelectorAll('.article-body h2, .article-body h3');
  const tocList = document.getElementById('tocList');
  if (headings.length > 0 && tocList) {
    tocList.innerHTML = '';
    headings.forEach((h, i) => {
      h.id = `heading-${i}`;
      const li = document.createElement('li');
      li.className = `toc-item ${h.tagName === 'H3' ? 'h3' : ''}`;
      li.innerHTML = `<a href="#heading-${i}">${h.textContent}</a>`;
      tocList.appendChild(li);
    });
  }
</script>
</BaseLayout>
