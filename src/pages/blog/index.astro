---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.status === 'published');
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const catLabel: Record<string, string> = {
  seo: 'SEO', adsense: '애드센스', content: '콘텐츠 마케팅',
  trend: '마케팅 트렌드', tip: '마케팅 팁', case: '업종별 사례'
};
const tagStyle: Record<string, string> = {
  seo: 'background:var(--primary-light);color:var(--primary)',
  adsense: 'background:var(--accent-light);color:var(--accent)',
  content: 'background:var(--green-light);color:var(--green)',
  trend: 'background:#fff8ec;color:#f5a623',
  tip: 'background:#f0e8ff;color:#7c3aed',
  case: 'background:#fff8e1;color:#b45309',
};
const bgColors: Record<string, string> = {
  seo: 'linear-gradient(135deg,#e8f0ff,#c5d5ff)',
  adsense: 'linear-gradient(135deg,#fff0eb,#ffd5c5)',
  content: 'linear-gradient(135deg,#e3f5ef,#b8e8d8)',
  trend: 'linear-gradient(135deg,#fff8ec,#ffe4a0)',
  tip: 'linear-gradient(135deg,#f0e8ff,#d5b8ff)',
  case: 'linear-gradient(135deg,#fff8e1,#ffe082)',
};
const emojis: Record<string, string> = {
  seo: '🔍', adsense: '💰', content: '✍️', trend: '🤖', tip: '💡', case: '⚖️'
};

const featured = posts[0];
const rest = posts.slice(1);
---
<BaseLayout title="마케팅 블로그 — JNC마케팅" description="SEO, 키워드, 블로그 마케팅까지 — 법률사무소, 병원, 소상공인이 직접 써먹을 수 있는 전략만 다룹니다.">
<style>
  .page-header { padding: 60px 5% 48px; max-width: 1280px; margin: 0 auto; }
  .page-label { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--primary); margin-bottom: 12px; }
  .page-title { font-family: var(--font-serif); font-size: clamp(32px, 4vw, 50px); line-height: 1.2; letter-spacing: -0.02em; }
  .page-desc { font-size: 16px; color: var(--gray-600); margin-top: 14px; line-height: 1.7; max-width: 500px; }

  .filter-wrap { padding: 0 5% 40px; max-width: 1280px; margin: 0 auto; }
  .filter-tabs { display: flex; gap: 8px; flex-wrap: wrap; }
  .filter-tab { padding: 9px 20px; border-radius: 100px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; border: 1.5px solid var(--gray-200); background: white; color: var(--gray-600); }
  .filter-tab:hover { border-color: var(--black); color: var(--black); }
  .filter-tab.active { background: var(--black); color: white; border-color: var(--black); }

  /* FEATURED */
  .featured-wrap { padding: 0 5%; max-width: 1280px; margin: 0 auto 48px; }
  .featured-card { background: white; border-radius: 20px; display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; box-shadow: var(--shadow); transition: transform 0.22s, box-shadow 0.22s; }
  .featured-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .featured-thumb { display: flex; align-items: center; justify-content: center; font-size: 96px; min-height: 320px; }
  .featured-body { padding: 48px 44px; display: flex; flex-direction: column; justify-content: center; }
  .featured-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; background: #fff3cd; color: #8a6200; padding: 5px 12px; border-radius: 100px; margin-bottom: 20px; width: fit-content; }
  .featured-badge::before { content: '★'; }
  .featured-title { font-family: var(--font-serif); font-size: 24px; line-height: 1.4; margin-bottom: 14px; }
  .featured-excerpt { font-size: 14px; color: var(--gray-600); line-height: 1.7; margin-bottom: 24px; }
  .featured-meta { font-size: 12px; color: var(--gray-400); display: flex; gap: 10px; margin-bottom: 24px; }
  .read-more { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 700; color: var(--primary); transition: gap 0.2s; }
  .read-more:hover { gap: 10px; }
  .read-more::after { content: '→'; }

  /* GRID */
  .grid-wrap { padding: 0 5%; max-width: 1280px; margin: 0 auto; }
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .post-card { background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); transition: transform 0.22s, box-shadow 0.22s; display: block; animation: fadeUp 0.5s ease both; }
  .post-card:hover { transform: translateY(-5px); box-shadow: var(--shadow); }
  .post-thumb { width: 100%; aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; font-size: 44px; }
  .post-body { padding: 22px; }
  .post-title { font-size: 16px; font-weight: 700; line-height: 1.45; margin-bottom: 10px; }
  .post-excerpt { font-size: 13px; color: var(--gray-600); line-height: 1.65; margin-bottom: 16px; }
  .post-meta { font-size: 12px; color: var(--gray-400); display: flex; gap: 8px; justify-content: space-between; }
  .post-read-time { background: var(--gray-100); padding: 2px 8px; border-radius: 100px; font-size: 11px; }
  .empty-state { grid-column: span 3; text-align: center; padding: 64px; color: var(--gray-400); font-size: 15px; }

  .load-more-wrap { text-align: center; padding: 48px 0 80px; }
  .load-more-btn { display: inline-flex; align-items: center; gap: 8px; background: white; color: var(--black); padding: 14px 32px; border-radius: 100px; font-size: 15px; font-weight: 600; border: 1.5px solid var(--gray-200); cursor: pointer; transition: border-color 0.2s, transform 0.15s; font-family: var(--font-sans); }
  .load-more-btn:hover { border-color: var(--black); transform: translateY(-2px); }

  footer.blog-footer { background: var(--black); color: rgba(255,255,255,0.45); padding: 40px 5%; }

  @media (max-width: 1024px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-thumb { min-height: 200px; font-size: 72px; }
    .posts-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .page-header { padding: 40px 20px 32px; }
    .filter-wrap { padding: 0 20px 32px; }
    .featured-wrap { padding: 0 20px; }
    .featured-body { padding: 28px 24px; }
    .featured-title { font-size: 20px; }
    .grid-wrap { padding: 0 20px; }
    .posts-grid { grid-template-columns: 1fr; }
    .empty-state { grid-column: auto; }
  }
</style>

<div class="page-header">
  <div class="page-label">JNC 마케팅 블로그</div>
  <div class="page-title">실전에서 바로 쓰는<br>마케팅 인사이트</div>
  <div class="page-desc">SEO, 키워드, 블로그 마케팅까지 — 법률사무소, 병원, 소상공인이 직접 써먹을 수 있는 전략만 다룹니다.</div>
</div>

<div class="filter-wrap">
  <div class="filter-tabs">
    <button class="filter-tab active" onclick="filterPosts('all',this)">전체</button>
    <button class="filter-tab" onclick="filterPosts('seo',this)">SEO</button>
    <button class="filter-tab" onclick="filterPosts('adsense',this)">애드센스</button>
    <button class="filter-tab" onclick="filterPosts('content',this)">콘텐츠 마케팅</button>
    <button class="filter-tab" onclick="filterPosts('trend',this)">마케팅 트렌드</button>
    <button class="filter-tab" onclick="filterPosts('tip',this)">마케팅 팁</button>
    <button class="filter-tab" onclick="filterPosts('case',this)">업종별 사례</button>
  </div>
</div>

{featured && (
  <div class="featured-wrap">
    <a class="featured-card" href={`/blog/${featured.slug}/`}>
      <div class="featured-thumb" style={`background:${bgColors[featured.data.category] || bgColors.seo}`}>
        {emojis[featured.data.category] || '📝'}
      </div>
      <div class="featured-body">
        <div class="featured-badge">최신 글</div>
        <div><span class="blog-tag" style={tagStyle[featured.data.category]}>{catLabel[featured.data.category] || featured.data.category}</span></div>
        <div class="featured-title">{featured.data.title}</div>
        <div class="featured-excerpt">{featured.data.summary}</div>
        <div class="featured-meta">
          <span>JNC마케팅팀</span><span>·</span><span>{featured.data.date}</span>
          {featured.data.readTime && <span>·</span>}<span>{featured.data.readTime}</span>
        </div>
        <span class="read-more">자세히 읽기</span>
      </div>
    </a>
  </div>
)}

<div class="grid-wrap">
  <div class="posts-grid" id="postsGrid">
    {rest.length === 0 && !featured && (
      <div class="empty-state">📝 아직 발행된 글이 없습니다</div>
    )}
    {rest.map((post, i) => (
      <a class="post-card" href={`/blog/${post.slug}/`} data-category={post.data.category}
         style={`animation-delay:${i * 0.07}s`}>
        <div class="post-thumb" style={`background:${bgColors[post.data.category] || bgColors.seo}`}>
          {emojis[post.data.category] || '📝'}
        </div>
        <div class="post-body">
          <div><span class="blog-tag" style={tagStyle[post.data.category]}>{catLabel[post.data.category] || post.data.category}</span></div>
          <div class="post-title">{post.data.title}</div>
          <div class="post-excerpt">{post.data.summary}</div>
          <div class="post-meta">
            <span>{post.data.date}</span>
            {post.data.readTime && <span class="post-read-time">{post.data.readTime}</span>}
          </div>
        </div>
      </a>
    ))}
  </div>
  <div class="load-more-wrap">
    <button class="load-more-btn">더 많은 글 보기 ↓</button>
  </div>
</div>

<script>
function filterPosts(cat: string, btn: HTMLElement) {
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.post-card').forEach((card: Element) => {
    const el = card as HTMLElement;
    el.style.display = (cat === 'all' || el.dataset.category === cat) ? 'block' : 'none';
  });
}
</script>
</BaseLayout>
