---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({data}) => data.status === 'published'))
  .sort((a,b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const catLabel: Record<string,string> = { seo:'SEO', adsense:'애드센스', content:'콘텐츠 마케팅', trend:'트렌드', tip:'마케팅 팁', case:'업종별 사례' };
const bgColors: Record<string,string> = { seo:'linear-gradient(135deg,#e8f0ff,#c5d5ff)', adsense:'linear-gradient(135deg,#fff0eb,#ffd5c5)', content:'linear-gradient(135deg,#e3f5ef,#b8e8d8)', trend:'linear-gradient(135deg,#fff8ec,#ffe4a0)', tip:'linear-gradient(135deg,#f0e8ff,#d5b8ff)', case:'linear-gradient(135deg,#fff8e1,#ffe082)' };
const emojis: Record<string,string> = { seo:'🔍', adsense:'💰', content:'✍️', trend:'🤖', tip:'💡', case:'⚖️' };
---
<BaseLayout title="JNC마케팅 — 소상공인 & 전문직 마케팅 파트너" description="JNC마케팅은 법률사무소, 학원 등 소상공인 & 전문직 특화 마케팅 대행사입니다. 2013년부터 키워드·블로그·광고 마케팅으로 매출을 높여드립니다.">
<style>
  /* HERO */
  .hero { padding: 80px 5% 70px; display: grid; grid-template-columns: 1fr 480px; gap: 60px; align-items: center; max-width: 1280px; margin: 0 auto; }
  .hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--primary); background: var(--primary-light); padding: 6px 14px; border-radius: 100px; margin-bottom: 24px; }
  .hero-eyebrow::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--primary); }
  .hero h1 { font-family: var(--font-serif); font-size: clamp(36px, 4.5vw, 60px); line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 22px; }
  .hero h1 strong { color: var(--primary); }
  .hero-desc { font-size: 17px; color: var(--gray-600); max-width: 460px; line-height: 1.75; margin-bottom: 36px; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--primary); color: white; padding: 15px 30px; border-radius: 100px; font-size: 15px; font-weight: 700; box-shadow: 0 4px 20px rgba(0,82,204,0.3); transition: transform 0.15s, box-shadow 0.2s; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,82,204,0.4); }
  .btn-outline { display: inline-flex; align-items: center; gap: 8px; background: white; color: var(--black); padding: 15px 30px; border-radius: 100px; font-size: 15px; font-weight: 600; border: 1.5px solid var(--gray-200); transition: border-color 0.2s, transform 0.15s; }
  .btn-outline:hover { border-color: var(--black); transform: translateY(-2px); }
  .hero-trust { display: flex; align-items: center; gap: 12px; margin-top: 28px; font-size: 13px; color: var(--gray-400); }
  .trust-avatars { display: flex; }
  .trust-avatar { width: 32px; height: 32px; border-radius: 50%; border: 2px solid white; margin-left: -8px; display: flex; align-items: center; justify-content: center; font-size: 14px; background: var(--gray-100); }
  .trust-avatar:first-child { margin-left: 0; }

  /* METRICS */
  .metrics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .metric-card { background: white; border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow); transition: transform 0.2s; animation: fadeUp 0.6s ease both; }
  .metric-card:hover { transform: translateY(-3px); }
  .metric-card:nth-child(1){animation-delay:0.1s} .metric-card:nth-child(2){animation-delay:0.2s} .metric-card:nth-child(3){animation-delay:0.3s} .metric-card:nth-child(4){animation-delay:0.4s}
  .metric-card.accent { background: var(--primary); color: white; grid-column: span 2; }
  .metric-icon { font-size: 26px; margin-bottom: 10px; }
  .metric-num { font-family: var(--font-serif); font-size: 36px; font-weight: 700; line-height: 1; margin-bottom: 4px; }
  .metric-label { font-size: 12px; color: var(--gray-400); }
  .metric-card.accent .metric-label { color: rgba(255,255,255,0.65); }
  .metric-card.accent .metric-num { color: white; }
  .metric-desc { font-size: 14px; color: rgba(255,255,255,0.85); margin-top: 6px; line-height: 1.5; }

  /* CLIENTS */
  .clients-wrap { background: var(--black); padding: 28px 5%; overflow: hidden; }
  .clients-label { text-align: center; font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.35); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 20px; }
  .clients-scroll { display: flex; gap: 48px; animation: scroll 20s linear infinite; width: max-content; }
  .client-name { font-family: var(--font-serif); font-size: 18px; font-weight: 700; color: rgba(255,255,255,0.2); white-space: nowrap; }
  @keyframes scroll { from{transform:translateX(0)} to{transform:translateX(-50%)} }

  /* SERVICES */
  .services-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
  .service-card { background: white; border-radius: var(--radius); padding: 36px 32px; box-shadow: var(--shadow-sm); transition: transform 0.22s, box-shadow 0.22s; border: 1.5px solid transparent; position: relative; overflow: hidden; display: block; text-decoration: none; color: inherit; }
  .service-card::before { content:''; position:absolute; top:0; left:0; width:100%; height:3px; background:var(--primary); transform:scaleX(0); transform-origin:left; transition:transform 0.3s; }
  .service-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
  .service-card:hover::before { transform: scaleX(1); }
  .service-num { font-family: var(--font-serif); font-size: 42px; font-weight: 700; color: var(--gray-100); line-height: 1; margin-bottom: 20px; }
  .service-icon { font-size: 32px; margin-bottom: 16px; }
  .service-name { font-size: 18px; font-weight: 700; margin-bottom: 10px; }
  .service-desc { font-size: 14px; color: var(--gray-600); line-height: 1.7; margin-bottom: 20px; }
  .service-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .service-tag { font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 100px; background: var(--primary-light); color: var(--primary); }
  .service-more { margin-top: 20px; font-size: 13px; font-weight: 700; color: var(--primary); }

  /* ABOUT */
  .about-wrap { padding: 88px 5%; background: var(--black); }
  .about-inner { max-width: 1280px; margin: 0 auto; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
  .about-eyebrow { font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--primary); margin-bottom: 14px; }
  .about-title { font-family: var(--font-serif); font-size: clamp(26px,3vw,36px); color: white; line-height: 1.25; letter-spacing: -0.02em; margin-bottom: 22px; }
  .about-desc { font-size: 15px; color: rgba(255,255,255,0.55); line-height: 1.85; margin-bottom: 36px; }
  .about-timeline { display: flex; flex-direction: column; }
  .timeline-item { display: flex; gap: 20px; padding: 18px 0; border-bottom: 1px solid rgba(255,255,255,0.07); }
  .timeline-item:last-child { border-bottom: none; }
  .timeline-year { font-family: var(--font-serif); font-size: 14px; font-weight: 700; color: var(--primary); min-width: 64px; padding-top: 3px; flex-shrink: 0; }
  .timeline-title { font-size: 15px; font-weight: 700; color: white; margin-bottom: 4px; }
  .timeline-desc { font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.6; }
  .about-right { display: flex; flex-direction: column; gap: 14px; padding-top: 8px; }
  .about-value-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius); padding: 24px 28px; }
  .about-value-icon { font-size: 24px; margin-bottom: 10px; }
  .about-value-title { font-size: 16px; font-weight: 700; color: white; margin-bottom: 6px; }
  .about-value-desc { font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.65; }

  /* BLOG PREVIEW */
  .blog-wrap { background: white; padding: 88px 0; }
  .blog-inner { max-width: 1280px; margin: 0 auto; padding: 0 5%; }
  .blog-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 40px; }
  .view-all { font-size: 14px; font-weight: 600; color: var(--primary); display: flex; align-items: center; gap: 4px; transition: gap 0.2s; }
  .view-all:hover { gap: 8px; }
  .view-all::after { content: '→'; }
  .blog-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 20px; }
  .blog-card { background: var(--bg); border-radius: var(--radius); overflow: hidden; transition: transform 0.22s, box-shadow 0.22s; display: block; }
  .blog-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .blog-thumb { width: 100%; aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; font-size: 48px; }
  .blog-thumb-lg { aspect-ratio: 4/3; font-size: 72px; }
  .blog-body { padding: 20px; }
  .blog-title { font-size: 15px; font-weight: 700; line-height: 1.45; margin-bottom: 8px; }
  .blog-title-lg { font-size: 19px; }
  .blog-excerpt { font-size: 13px; color: var(--gray-600); line-height: 1.65; margin-bottom: 14px; }
  .blog-meta { font-size: 12px; color: var(--gray-400); display: flex; gap: 8px; }

  /* CTA */
  .cta-wrap { padding: 80px 5%; }
  .cta-inner { max-width: 1280px; margin: 0 auto; background: var(--primary); border-radius: 20px; padding: 64px 72px; display: grid; grid-template-columns: 1fr 420px; align-items: center; gap: 64px; position: relative; overflow: hidden; }
  .cta-inner::after { content:'📊'; position:absolute; font-size:200px; right:460px; top:-30px; opacity:0.07; pointer-events:none; }
  .cta-label { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 14px; }
  .cta-title { font-family: var(--font-serif); font-size: clamp(28px,3vw,40px); color: white; line-height: 1.3; margin-bottom: 16px; }
  .cta-desc { font-size: 15px; color: rgba(255,255,255,0.65); line-height: 1.75; }
  .form-card { background: white; border-radius: 16px; padding: 32px 28px; box-shadow: 0 16px 56px rgba(0,0,0,0.25); }
  .form-card-title { font-size: 17px; font-weight: 700; margin-bottom: 4px; }
  .form-card-sub { font-size: 13px; color: var(--gray-600); margin-bottom: 20px; }
  .f-label { font-size: 13px; font-weight: 600; color: var(--gray-600); display: block; margin-bottom: 5px; }
  .f-input, .f-textarea { width: 100%; padding: 11px 14px; border: 1.5px solid var(--gray-200); border-radius: 8px; font-size: 14px; font-family: var(--font-sans); outline: none; background: var(--bg); margin-bottom: 12px; transition: border-color 0.2s; }
  .f-input:focus, .f-textarea:focus { border-color: var(--primary); background: white; }
  .f-textarea { resize: vertical; min-height: 90px; }
  .f-btn { width: 100%; padding: 13px; background: var(--primary); color: white; border: none; border-radius: 8px; font-size: 15px; font-weight: 700; cursor: pointer; font-family: var(--font-sans); transition: background 0.2s; }
  .f-btn:hover { background: #0040a0; }
  .f-note { font-size: 11px; color: var(--gray-400); text-align: center; margin-top: 8px; }

  /* MOBILE */
  .hero-left > * { animation: fadeUp 0.55s ease both; }
  .hero-left > *:nth-child(1){animation-delay:0.05s} .hero-left > *:nth-child(2){animation-delay:0.12s} .hero-left > *:nth-child(3){animation-delay:0.2s} .hero-left > *:nth-child(4){animation-delay:0.28s} .hero-left > *:nth-child(5){animation-delay:0.36s}
  .hero-right { animation: fadeUp 0.6s 0.25s ease both; }

  @media (max-width: 1024px) {
    .hero { grid-template-columns: 1fr; }
    .hero-right { display: none; }
    .about-grid { grid-template-columns: 1fr; gap: 48px; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .blog-grid { grid-template-columns: 1fr 1fr; }
    .blog-card:first-child { grid-column: span 2; }
    .cta-inner { grid-template-columns: 1fr; padding: 48px 40px; }
    .cta-inner::after { display: none; }
  }
  @media (max-width: 768px) {
    .hero { padding: 52px 20px 48px; }
    .services-grid { grid-template-columns: 1fr; }
    .blog-grid { grid-template-columns: 1fr; }
    .blog-card:first-child { grid-column: auto; }
    .about-wrap { padding: 60px 20px; }
    .blog-wrap { padding: 60px 0; }
    .blog-inner { padding: 0 20px; }
    .cta-wrap { padding: 48px 20px; }
    .cta-inner { padding: 40px 28px; border-radius: 16px; }
    .cta-title { font-size: 26px; }
    .section-wrap { padding: 60px 20px; }
    .clients-wrap { padding: 24px 20px; }
  }
</style>

<!-- HERO -->
<section style="background:var(--bg)">
  <div class="hero">
    <div class="hero-left">
      <div class="hero-eyebrow">소상공인 & 전문직 마케팅 파트너</div>
      <h1>매출이 오르는<br><strong>마케팅 전략</strong>,<br>JNC가 만듭니다</h1>
      <p class="hero-desc">법률사무소, 학원, 자동차직업전문학교 등 — 전문직과 소상공인에 꼭 맞는 실전 마케팅으로 눈에 보이는 성과를 만들어드립니다.</p>
      <div class="hero-actions">
        <a class="btn-primary" href="#contact">무료 상담 신청 →</a>
        <a class="btn-outline" href="/services/">서비스 보기</a>
      </div>
      <div class="hero-trust">
        <div class="trust-avatars">
          <div class="trust-avatar">😊</div><div class="trust-avatar">🙂</div><div class="trust-avatar">😄</div><div class="trust-avatar">😎</div>
        </div>
        <span>법률·학원·소상공인 <strong style="color:var(--black)">전문직 특화</strong> 마케팅</span>
      </div>
    </div>
    <div class="hero-right">
      <div class="metrics-grid">
        <div class="metric-card"><div class="metric-icon">📅</div><div class="metric-num" style="font-size:20px;line-height:1.4;">2013<span style="font-size:16px">년</span></div><div class="metric-label">설립 · 업력 13년</div></div>
        <div class="metric-card"><div class="metric-icon">⚖️</div><div class="metric-num" style="font-size:20px;line-height:1.4;">법률 · 학원<br>소상공인 특화</div><div class="metric-label">전문직 마케팅 전문</div></div>
        <div class="metric-card"><div class="metric-icon">🔍</div><div class="metric-num" style="font-size:20px;line-height:1.4;">키워드 ·<br>블로그</div><div class="metric-label">매출 직결 마케팅</div></div>
        <div class="metric-card"><div class="metric-icon">🤝</div><div class="metric-num" style="font-size:18px;line-height:1.4;">비용에<br>책임</div><div class="metric-label">고객 비용 지출 책임제</div></div>
        <div class="metric-card accent"><div class="metric-icon">💡</div><div class="metric-num">지금 무료 진단 중</div><div class="metric-desc">우리 회사 마케팅, 어디서부터 시작해야 할지 모르겠다면? 30분 무료 컨설팅을 받아보세요.</div></div>
      </div>
    </div>
  </div>
</section>

<!-- CLIENTS -->
<div class="clients-wrap">
  <div class="clients-label">함께해온 업종</div>
  <div style="overflow:hidden">
    <div class="clients-scroll">
      {['법률사무소','병원 / 의원','자동차직업전문학교','소상공인','학원 / 교육','뷰티 / 미용','부동산','제조업','법률사무소','병원 / 의원','자동차직업전문학교','소상공인','학원 / 교육','뷰티 / 미용','부동산','제조업'].map((name,i) => (
        <span class="client-name">{name}{i%8!==7 && <>&nbsp;·</>}</span>
      ))}
    </div>
  </div>
</div>

<!-- SERVICES -->
<div id="services">
  <div class="section-wrap">
    <div style="margin-bottom:48px">
      <div class="section-label-tag">서비스</div>
      <div class="section-title">전문직 · 소상공인을 위한<br>마케팅 솔루션</div>
      <div class="section-desc">법률사무소, 학원 등 업종별 특성을 이해하는 마케팅 전략을 제공합니다.</div>
    </div>
    <div class="services-grid">
      {[
        {num:'01',icon:'🎯',name:'마케팅 컨설팅',desc:'업종별 현황 진단부터 실행 가능한 전략 수립까지. 법률, 교육 등 전문직 특성에 맞춘 맞춤형 로드맵을 제공합니다.',tags:['현황 진단','전략 수립','업종별 특화'],href:'/services/'},
        {num:'02',icon:'📢',name:'광고 대행',desc:'네이버, 구글, 메타 광고를 데이터 기반으로 운영합니다. 소상공인·전문직 예산 규모에 맞게 낭비 없이 전환율을 극대화합니다.',tags:['네이버 광고','구글 광고','SNS 광고'],href:'/services/#advertising'},
        {num:'03',icon:'🔍',name:'키워드 · 블로그 마케팅',desc:'검색 상위 노출로 지속적인 무료 트래픽을 확보합니다. 법률·교육·소상공인 업종의 핵심 키워드 전략으로 매출에 직접 기여합니다.',tags:['키워드 분석','블로그 마케팅','콘텐츠 SEO'],href:'/services/#keyword'},
      ].map(s => (
        <a class="service-card" href={s.href}>
          <div class="service-num">{s.num}</div>
          <div class="service-icon">{s.icon}</div>
          <div class="service-name">{s.name}</div>
          <div class="service-desc">{s.desc}</div>
          <div class="service-tags">{s.tags.map(t => <span class="service-tag">{t}</span>)}</div>
          <div class="service-more">자세히 보기 →</div>
        </a>
      ))}
    </div>
    <div style="text-align:center;margin-top:40px"><a href="/services/" class="btn-outline">서비스 전체 보기 →</a></div>
  </div>
</div>

<!-- ABOUT -->
<div class="about-wrap" id="about">
  <div class="about-inner">
    <div class="about-grid">
      <div>
        <div class="about-eyebrow">Our Story</div>
        <div class="about-title">우리는 단단하게<br>성장하고 있어요</div>
        <p class="about-desc">제이엔씨마케팅은 2013년 법률사무소와의 인연을 시작으로 설립되었습니다. 이후 법률마케팅을 주축으로 하면서 소상공인 마케팅까지 영역을 넓히며 함께 성장해왔습니다.<br><br>현재는 키워드 마케팅, 블로그 마케팅 등 고객의 매출에 직접적인 영향을 주는 적극적인 방식으로 진화했습니다.</p>
        <div class="about-timeline">
          {[['2013','법률사무소와의 인연으로 설립','법률 분야 마케팅 특화 — 업종 이해 기반의 전략 수립 시작'],['2015','업종 특성에 맞는 온라인 마케팅 체계 구축','각 업종의 고객 특성과 검색 패턴을 분석한 맞춤형 전략 체계화'],['2018','다양한 업종으로 확장','소상공인 전반으로 영역 확장'],['2020~','키워드·블로그 통합 마케팅 전면화','고객 매출에 직접 기여하는 적극적 마케팅 전략으로 2026년 현재까지 성장 중']].map(([year,title,desc]) => (
            <div class="timeline-item">
              <div class="timeline-year">{year}</div>
              <div><div class="timeline-title">{title}</div><div class="timeline-desc">{desc}</div></div>
            </div>
          ))}
        </div>
      </div>
      <div class="about-right">
        {[['⚖️','업종을 이해하는 마케팅','법률사무소, 학원, 소상공인 등 각 업종은 고객 심리와 검색 패턴이 다릅니다. 업종별 특성을 깊이 이해한 전략으로 접근합니다.'],['🤝','비용 지출에 책임을 다합니다','소상공인에게 마케팅 예산은 소중합니다. 동반성장을 목표로 고객의 비용 지출 한 푼 한 푼에 책임감을 갖고 일합니다.'],['📅','2013년부터 쌓아온 실전 노하우','13년간 법률, 교육, 소상공인 분야에서 직접 쌓은 실전 경험이 전략의 기반입니다.']].map(([icon,title,desc]) => (
          <div class="about-value-card">
            <div class="about-value-icon">{icon}</div>
            <div class="about-value-title">{title}</div>
            <div class="about-value-desc">{desc}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<!-- BLOG PREVIEW -->
<div class="blog-wrap">
  <div class="blog-inner">
    <div class="blog-header">
      <div>
        <div class="section-label-tag">마케팅 블로그</div>
        <div class="section-title">실전에서 바로 쓰는<br>마케팅 인사이트</div>
      </div>
      <a class="view-all" href="/blog/">전체 글 보기</a>
    </div>
    <div class="blog-grid">
      {recentPosts.length === 0 ? (
        <div style="grid-column:span 3;text-align:center;padding:48px;color:var(--gray-400)">아직 발행된 글이 없습니다</div>
      ) : recentPosts.map((post, i) => (
        <a class="blog-card" href={`/blog/${post.slug}/`}>
          <div class={`blog-thumb${i===0?' blog-thumb-lg':''}`} style={`background:${bgColors[post.data.category]||bgColors.seo}`}>{emojis[post.data.category]||'📝'}</div>
          <div class="blog-body">
            <span class="blog-tag tag-blue">{catLabel[post.data.category]||post.data.category}</span>
            <div class={`blog-title${i===0?' blog-title-lg':''}`}>{post.data.title}</div>
            {i===0 && <div class="blog-excerpt">{post.data.summary}</div>}
            <div class="blog-meta"><span>JNC마케팅팀</span><span>·</span><span>{post.data.date}</span></div>
          </div>
        </a>
      ))}
    </div>
  </div>
</div>

<!-- CTA + FORM -->
<div class="cta-wrap" id="contact">
  <div class="cta-inner">
    <div>
      <div class="cta-label">무료 상담</div>
      <div class="cta-title">우리 회사 마케팅,<br>어디서부터 시작해야 할까요?</div>
      <p class="cta-desc">30분 무료 컨설팅으로 현재 문제점과 우선순위를 짚어드립니다.</p>
      <div style="margin-top:28px;display:flex;flex-direction:column;gap:10px">
        <div style="color:rgba(255,255,255,0.65);font-size:14px">✅ 30분 무료 상담</div>
        <div style="color:rgba(255,255,255,0.65);font-size:14px">✅ 법률·학원·소상공인 업종 특화</div>
        <div style="color:rgba(255,255,255,0.65);font-size:14px">✅ 2013년부터 13년 실전 노하우</div>
      </div>
    </div>
    <div class="form-card">
      <div class="form-card-title">무료 상담 신청</div>
      <div class="form-card-sub">1~2 영업일 내로 연락드립니다.</div>
      <form name="contact" method="POST" data-netlify="true">
        <input type="hidden" name="form-name" value="contact">
        <label class="f-label">이름 *</label>
        <input class="f-input" name="name" type="text" placeholder="홍길동" required>
        <label class="f-label">연락처 *</label>
        <input class="f-input" name="phone" type="tel" placeholder="010-0000-0000" required>
        <label class="f-label">문의 내용 *</label>
        <textarea class="f-textarea" name="message" placeholder="업종, 현재 상황을 자유롭게 적어주세요." required></textarea>
        <button class="f-btn" type="submit">무료 상담 신청하기 →</button>
        <div class="f-note">개인정보는 상담 목적 외 사용되지 않습니다.</div>
      </form>
    </div>
  </div>
</div>
</BaseLayout>
